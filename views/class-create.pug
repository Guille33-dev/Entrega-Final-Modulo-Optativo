extends layout

block content
  h1= title
  p.lead Define el horario, el nivel y el entrenador responsable de la nueva clase.
  if error
    p.error= error
  form.form(method="POST", action="/classes")
    label(for="title") Nombre de la clase
    input(type="text", name="title", id="title", required, minlength="3", maxlength="80", placeholder="Yoga inicial")

    label(for="level") Nivel
    select(name="level", id="level")
      option(value="beginner") Principiante
      option(value="intermediate") Intermedio
      option(value="advanced") Avanzado

    label(for="capacity") Plazas disponibles
    input(type="number", name="capacity", id="capacity", required, min="1", max="60", value="20")

    label(for="durationMinutes") Duración en minutos
    input(type="number", name="durationMinutes", id="durationMinutes", min="15", max="180", value="60")

    label(for="startsAt") Fecha y hora de inicio
    input(type="datetime-local", name="startsAt", id="startsAt", required)

    label(for="trainer") Entrenador asignado
    select(name="trainer", id="trainer", required)
      each trainer in trainers
        option(value=trainer._id)= trainer.name

    button.button(type="submit") Guardar clase
